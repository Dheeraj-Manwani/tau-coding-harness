generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())

  oauthAccounts OAuthAccount[]
  refreshTokens RefreshToken[]
  projects      Project[]
  tokenUsage    TokenUsage[]

  billing       BillingAccount?
  promoRedeems  PromoRedemption[]
  subscriptions Subscription[]
}

model OAuthAccount {
  id                String    @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

enum ClientType {
  web
  mobile
}

model RefreshToken {
  id         String     @id @default(uuid())
  userId     String
  tokenHash  String     @unique
  clientType ClientType
  deviceInfo Json?
  createdAt  DateTime   @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_refresh_tokens_user")
}

model Project {
  id        String   @id @default(uuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sandboxId        String?
  sandboxStatus    SandboxStatus @default(NONE)
  sandboxExpiresAt DateTime?

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  jobs       Job[]
  tokenUsage TokenUsage[]

  headSequence Int           @default(0)
  files        ProjectFile[]

  @@index([userId])
}

enum SandboxStatus {
  NONE
  PROVISIONING
  READY
  HIBERNATED
  DEAD
}

enum MessageRole {
  USER
  ASSISTANT
}

enum MessageType {
  USER
  RESULT
  ERROR
  TOOL_REQ
  TOOL_RES
}

model Message {
  id   String      @id @default(uuid())
  role MessageRole
  type MessageType

  content  Json
  sequence Int

  inputTokens  Int @default(0)
  outputTokens Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id])

  fragment  Fragment?
  toolCalls ToolCall[]

  @@unique([projectId, sequence])
  @@index([projectId])
  @@index([jobId])
}

model ToolCall {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  toolCallId String
  toolName   String
  input      Json

  status      ToolCallStatus @default(PENDING)
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([messageId])
  @@index([toolCallId])
}

enum ToolCallStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model Job {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  status JobStatus @default(QUEUED)
  type   JobType   @default(GENERATION)
  prompt String

  queueJobId String? @unique

  queuedAt    DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  error         String?
  attemptNumber Int     @default(1)
  maxAttempts   Int     @default(2)

  messages   Message[]
  tokenUsage TokenUsage[]
  fragments  Fragment[]

  @@index([projectId])
  @@index([status])
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  GENERATION
  RECOVERY
}

model ProjectFile {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  path         String
  contentHash  String
  sizeBytes    Int
  lastSequence Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, path])
  @@index([projectId])
}

model Fragment {
  id        String  @id @default(uuid())
  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  sandboxUrl  String
  title       String
  description String?

  jobId String?
  job   Job?    @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Usage {
  key    String    @id
  points Int
  expire DateTime?
}

model TokenUsage {
  id        String @id @default(uuid())
  userId    String
  projectId String
  jobId     String
  model     String

  inputTokens  Int
  outputTokens Int

  recordedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  job     Job     @relation(fields: [jobId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([projectId])
  @@index([jobId])
  @@index([recordedAt])
}

// ───────────────────────────── Credits & billing ─────────────────────────────

enum Plan {
  FREE
  PRO
}

// One row per user; the row we lock (SELECT … FOR UPDATE) to serialize spend.
model BillingAccount {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan Plan @default(FREE)

  freeBalance  BigInt @default(0) // daily-reset bucket
  planBalance  BigInt @default(0) // monthly-reset bucket (active plan)
  bonusBalance BigInt @default(0) // never expires (promos, top-ups, refunds)
  reserved     BigInt @default(0) // sum of ACTIVE holds; earmark, not a ledger event

  dailyAllotment BigInt    @default(0) // micro-credits granted to the free bucket per day
  freeRefilledAt DateTime?

  cycleStart DateTime? // current plan billing cycle
  cycleEnd   DateTime?

  razorpayCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledger CreditLedger[]
  holds  CreditHold[]
}

enum LedgerType {
  SIGNUP_GRANT
  DAILY_FREE_GRANT
  PLAN_GRANT
  PROMO_REDEEM
  PURCHASE
  DEBIT
  REFUND
  EXPIRE
  ADJUSTMENT
}

// Append-only money record. Invariant (gross balance) == Σ amount per account.
model CreditLedger {
  id      String         @id @default(uuid())
  userId  String
  account BillingAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)

  type         LedgerType
  amount       BigInt // signed micro-credits (+grant / −debit)
  balanceAfter BigInt // gross (free+plan+bonus) snapshot, for audit

  jobId             String?
  holdId            String?
  promoRedemptionId String?
  paymentId         String?

  idempotencyKey String?  @unique // dedupes retries & webhook redelivery
  reason         String?
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([jobId])
}

enum HoldStatus {
  ACTIVE
  SETTLED
  RELEASED
}

// One hold per job — the reserved ceiling a job may spend.
model CreditHold {
  id      String         @id @default(uuid())
  userId  String
  account BillingAccount @relation(fields: [userId], references: [userId], onDelete: Cascade)
  jobId   String         @unique

  amount   BigInt // reserved ceiling
  consumed BigInt     @default(0) // metered so far against this hold
  status   HoldStatus @default(ACTIVE)

  createdAt DateTime  @default(now())
  settledAt DateTime?

  @@index([userId])
}

model PromoCode {
  id          String  @id @default(uuid())
  code        String  @unique // store normalized (uppercased, trimmed)
  credits     BigInt // micro-credits granted to bonusBalance
  description String?

  maxRedemptions Int? // null = unlimited
  redeemedCount  Int  @default(0)
  perUserLimit   Int  @default(1)

  expiresAt DateTime?
  isActive  Boolean   @default(true)

  createdAt   DateTime          @default(now())
  redemptions PromoRedemption[]
}

model PromoRedemption {
  id     String    @id @default(uuid())
  codeId String
  code   PromoCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  creditsGranted BigInt
  createdAt      DateTime @default(now())

  @@unique([codeId, userId]) // DB-enforced single redemption per user
  @@index([userId])
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  CANCELLED
  COMPLETED
  EXPIRED
}

model Subscription {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   Plan
  status SubscriptionStatus

  razorpaySubscriptionId String  @unique
  razorpayPlanId         String
  razorpayCustomerId     String?

  currentStart     DateTime?
  currentEnd       DateTime?
  cancelAtCycleEnd Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Idempotent webhook processing (Razorpay can redeliver events).
model WebhookEvent {
  id          String    @id // provider event id (e.g. x-razorpay-event-id)
  provider    String
  type        String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}
