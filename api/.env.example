# ─────────────────────────────────────────────────────────────
# SHARED — keep identical across api / ws-gateway / worker-service
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgres://tau:tau@localhost:5432/tau"
REDIS_URL=redis://localhost:6379

# Signs the HS256 access/connection tokens. ws-gateway verifies with this.
ACCESS_TOKEN_SECRET=change-me-min-16-chars

# ─────────────────────────────────────────────────────────────
# api-specific
# ─────────────────────────────────────────────────────────────
PORT=3000

# Deepseek (LLM) — shared with worker-service
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Email (Resend)
EMAIL_FROM=Tau <onboarding@resend.dev>
RESEND_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
