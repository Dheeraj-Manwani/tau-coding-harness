# ─────────────────────────────────────────────────────────────
# SHARED — keep identical across api / ws-gateway / worker-service
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgres://tau:tau@localhost:5432/tau"
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# worker-service-specific
# ─────────────────────────────────────────────────────────────
# Deepseek (LLM) — shared with api
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Optional: defaults shown below
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# E2B sandbox
E2B_API_KEY=e2b-your-api-key

# R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=tau-files
R2_PUBLIC_BASE_URL=https://files.example.com

# Queue / worker (optional: defaults shown below)
QUEUE_NAME=code-generation
WORKER_CONCURRENCY=3

# Credits / billing — "true" enforces credit charging; "false" = shadow mode
CREDITS_ENFORCE=false
