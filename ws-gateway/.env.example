# ─────────────────────────────────────────────────────────────
# SHARED — keep identical across api / ws-gateway / worker-service
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Must match api's ACCESS_TOKEN_SECRET so connection tokens verify here.
ACCESS_TOKEN_SECRET=change-me-min-16-chars

# ─────────────────────────────────────────────────────────────
# ws-gateway-specific
# ─────────────────────────────────────────────────────────────
PORT=3001
